generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum AddressType {
  CORRESPONDENCE
  DELIVERY
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ProductCategory {
  BATTERY
  SOLAR
  HEAT_PUMP
  CHARGER
  EMERGENCY_POWER
}

enum QuoteType {
  EIGEN_INVESTERING
  GEFINANCIERD
}

enum FinancingType {
  WARMTEFONDS
  SVN
  BANK
  OVERIG
}

enum HouseType {
  TERRACED
  CORNER
  DETACHED
  APARTMENT
}

enum UserRole {
  ADMIN
  SALES
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  QUOTE_SENT
  WON
  LOST
}

// ── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  role      UserRole @default(SALES)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes     Quote[]
  customers  Customer[]
  products   Product[]
  leads      Lead[]
  leadNotes  LeadNote[]
}

model Customer {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  dateOfBirth DateTime
  iban        String?
  email       String?
  phone       String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  addresses Address[]
  quotes    Quote[]
}

model Address {
  id          String      @id @default(cuid())
  type        AddressType
  street      String
  houseNumber String
  postalCode  String
  city        String
  country     String      @default("NL")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Product {
  id          String          @id @default(cuid())
  name        String
  description String?
  defaultQty  Float?
  unitPrice   Float
  vatRate     Float           @default(21)
  imageUrl    String?
  notes       String?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Categorie & specs
  category           ProductCategory?
  capacityKwh        Float?           // Batterij-capaciteit of opwek (kWh)
  powerKw            Float?           // Vermogen (kW)
  warrantyYears      Int?             // Garantietermijn
  savingsKwhYear     Float?           // Verwachte stroombesparing per jaar (kWh)
  gasReductionM3Year Float?           // Gasbesparing per jaar (m³) — warmtepomp

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  quoteLines QuoteLine[]
}

model Quote {
  id          String      @id @default(cuid())
  quoteNumber String      @unique
  status      QuoteStatus @default(DRAFT)
  title       String
  notes       String?
  introText   String?
  includedItems String?
  validUntil    DateTime?

  discountAmount Float @default(0)
  subtotal       Float @default(0)
  vatTotal       Float @default(0)
  total          Float @default(0)

  publicToken String @unique @default(uuid())
  termsText   String?

  sentAt     DateTime?
  acceptedAt DateTime?
  rejectedAt DateTime?
  archivedAt DateTime?

  // ── Offerteype ──────────────────────────────────────────────────────────
  quoteType     QuoteType @default(EIGEN_INVESTERING)

  // ── Financiering (alleen bij GEFINANCIERD) ───────────────────────────────
  financingType    FinancingType?
  loanInterestRate Float          @default(0.03)   // 3% p.j.
  loanTermYears    Int            @default(10)
  subsidyAmount    Float          @default(0)       // BTW-teruggave / subsidie
  hasBtwReturn     Boolean        @default(false)

  // ── Energieprofiel klant ─────────────────────────────────────────────────
  hasSolarPanels         Boolean @default(false)
  solarPanelKwp          Float?  // Piekvermogen zonnepanelen (kWp)
  solarProductionKwh     Float?  // Jaarlijkse opwek zonnepanelen (kWh)
  electricityUsageKwh    Float?  // Jaarverbruik stroom (kWh)
  electricityFeedbackKwh Float?  // Jaarlijkse teruglevering (kWh)
  gasUsageM3             Float?  // Jaarverbruik gas (m³)
  hasHeatPump            Boolean @default(false) // Klant heeft al een warmtepomp
  includeBatteryAdvice   Boolean @default(false) // Batterijadvies meesturen in offerte

  // Tarieven (met defaults, handmatig aanpasbaar)
  electricityTariff Float @default(0.28)  // €/kWh
  feedbackTariff    Float @default(0.07)  // €/kWh na saldering
  gasTariff         Float @default(1.10)  // €/m³
  feedInCostTariff  Float @default(0.02)  // €/kWh terugleverkosten leverancier

  // EMS / onbalansmarkt
  emsAnnualRevenueEur Float @default(0)   // Verwachte jaarlijkse EMS/onbalans opbrengst (€)

  // Huidig termijnbedrag klant
  currentMonthlyBill Float @default(0)    // Huidig maandelijks termijnbedrag energieleverancier (€)

  // Schatting-inputs (alternatief voor handmatige invoer)
  numPersons   Int?
  houseType    HouseType?
  buildYear    Int?
  houseSizeSqm Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  lines      QuoteLine[]
  acceptance QuoteAcceptance?
}

model QuoteLine {
  id          String   @id @default(cuid())
  sortOrder   Int      @default(0)
  name        String
  description String?
  quantity    Float
  unitPrice   Float
  vatRate     Float
  lineTotal   Float
  createdAt   DateTime @default(now())

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Lead {
  id          String     @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  street      String?
  houseNumber String?
  postalCode  String?
  city        String?
  status      LeadStatus @default(NEW)
  source      String?
  archivedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  notes LeadNote[]
}

model LeadNote {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])
}

model QuoteAcceptance {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  iban           String?
  agreedToTerms  Boolean  @default(false)
  signatureData  String
  acceptedAt     DateTime @default(now())
  ipAddress      String?
  acceptanceType String?

  quoteId String @unique
  quote   Quote  @relation(fields: [quoteId], references: [id])
}
